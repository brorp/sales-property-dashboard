PORT=3001
CORS_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_VERCEL_PREVIEW=false
CORS_ROOT_DOMAINS=propertylounge-cms.com
APP_ROOT_DOMAINS=propertylounge-cms.com
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/property_lounge

BETTER_AUTH_SECRET=replace-this-secret
BETTER_AUTH_URL=http://localhost:3001

# Fallback only. Saat WA_PROVIDER=qr_local dan session sudah connect,
# nomor aktif otomatis mengikuti akun WhatsApp yang discan.
PROPERTY_LOUNGE_WA=+620000000000
WHATSAPP_VERIFY_TOKEN=dev-verify-token

DISTRIBUTION_POLL_MS=15000
GOOGLE_CALENDAR_MOCK=true

# WhatsApp provider: dummy | qr_local | cloud_api
WA_PROVIDER=dummy

# For WA_PROVIDER=qr_local
WA_QR_AUTH_PATH=.wa-qr-auth
WA_ACTIVE_CLIENT_SLUG=widari
# Optional. Hanya dipakai kalau pilih flow "Link with phone number" (pairing code),
# bukan untuk scan QR biasa.
WA_PAIRING_PHONE=
ADMIN_WHATSAPP_TOKEN=

# For WA_PROVIDER=cloud_api
WA_CLOUD_API_TOKEN=
WA_CLOUD_PHONE_NUMBER_ID=
WA_CLOUD_API_VERSION=v21.0
